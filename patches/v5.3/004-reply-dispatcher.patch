+/**
+ * [HERMES-FOOTER] Decide whether to reply with a card.
+ * Original function only returns true if text contains code blocks or tables.
+ * We override to always use card mode when renderMode === 'card'.
+ */
+function shouldUseCard(text) {
+    // Original logic:
+    // return /\n```/s.test(text) || /\n\|/.test(text);
+    // Patched: always use card when renderMode === 'card'
+    try {
+        const channels = require('openclaw/plugin-sdk').getConfig?.()?.channels;
+        const feishuCfg = channels?.feishu;
+        if (feishuCfg?.renderMode === 'card') return true;
+    } catch (e) { /* ignore */ }
+    return /\n```/s.test(text) || /\n\|/.test(text);
+}
+
+/**
+ * [HERMES-FOOTER] Force visibleReplies to 'automatic' for card footer.
+ * The plugin checks messages.visibleReplies at the framework level, but
+ * the channel config's visibleReplies takes precedence. We ensure the
+ * feishu channel always uses 'automatic' so the reply is visible.
+ */
+function patchVisibleReplies(cfg) {
+    if (cfg?.channels?.feishu) {
+        cfg.channels.feishu.visibleReplies = 'automatic';
+    }
+    return cfg;
+}
+
+// Apply at module load time
+try {
+    const config = require('openclaw/plugin-sdk').getConfig();
+    patchVisibleReplies(config);
+} catch (e) { /* ignore */ }
