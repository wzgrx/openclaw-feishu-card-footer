{
  "_comment": "OpenClaw 配置模板 — 替换 YOUR_* 占位符后使用",

  "models": {
    "mode": "merge",
    "pricing": { "enabled": false },
    "providers": {
      "bailian": {
        "baseUrl": "https://coding.dashscope.aliyuncs.com/v1",
        "apiKey": "YOUR_BAILIAN_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.6-plus",
            "reasoning": true,
            "input": ["image", "text", "video"],
            "cost": { "input": 8, "output": 48, "cacheRead": 0.8 },
            "contextWindow": 1000000,
            "maxTokens": 65536,
            "compat": { "thinkingFormat": "openai" },
            "name": "Bailian qwen3.6-plus"
          }
        ]
      },
      "deepseek": {
        "baseUrl": "https://api.deepseek.com",
        "apiKey": "YOUR_DEEPSEEK_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-v4-flash",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 1, "output": 2, "cacheRead": 0.02 },
            "contextWindow": 1000000,
            "maxTokens": 384000,
            "compat": { "supportsReasoningEffort": true },
            "name": "DeepSeek deepseek-v4-flash"
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": "deepseek/deepseek-v4-flash",
      "systemPromptOverride": "你是龙虾机器人，一个智能助手。用中文回复。"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "model": "deepseek/deepseek-v4-flash",
        "systemPromptOverride": "你是龙虾机器人，一个智能助手。用中文回复。"
      }
    ]
  },

  "channels": {
    "feishu": {
      "appId": "YOUR_FEISHU_APP_ID",
      "appSecret": "YOUR_FEISHU_APP_SECRET",
      "connectionMode": "websocket",
      "enabled": true,
      "groups": { "*": { "enabled": true } },
      "groupPolicy": "open",
      "requireMention": false,
      "dmPolicy": "open",
      "renderMode": "card",
      "streaming": true,
      "replyMode": {
        "default": "auto",
        "direct": "streaming",
        "group": "streaming"
      },
      "footer": {
        "status": true,
        "elapsed": true,
        "tokens": true,
        "cache": true,
        "context": true,
        "model": true
      }
    }
  },

  "plugins": {
    "entries": {
      "openclaw-lark": { "enabled": true }
    },
    "allow": ["openclaw-lark"]
  },

  "tools": {
    "profile": "full",
    "sessions": { "visibility": "all" }
  },

  "commands": { "native": "auto" },

  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    }
  }
}
