{
  "_comment": "OpenClaw 配置模板 — 适配 feishu-card-footer 的必要配置",

  "agents": {
    "defaults": {
      "verboseDefault": "on",
      "blockStreamingDefault": "off"
    }
  },

  "channels": {
    "feishu": {
      "appId": "YOUR_APP_ID",
      "appSecret": "YOUR_APP_SECRET",
      "streaming": true,
      "groupPolicy": "open",
      "requireMention": false,
      "footer": {
        "status": true,
        "elapsed": true,
        "tokens": true,
        "cache": true,
        "context": true,
        "model": true
      }
    }
  },

  "plugins": {
    "allow": [
      "browser",
      "deepseek",
      "lossless-claw",
      "memory-core",
      "memory-wiki",
      "openclaw-lark"
    ],
    "slots": {
      "contextEngine": "lossless-claw"
    }
  }
}
